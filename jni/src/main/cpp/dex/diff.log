    // Returns the valid access flags, that is, Java modifier bits relevant to the ClassDef type																			    // Returns the valid access flags, that is, Java modifier bits relevant to the ClassDef type
    // (class or interface). These are all in the lower 16b and do not contain runtime flags.																				    // (class or interface). These are all in the lower 16b and do not contain runtime flags.
    uint32_t GetJavaAccessFlags() const {																										    uint32_t GetJavaAccessFlags() const {
      // Make sure that none of our runtime-only flags are set.																								      // Make sure that none of our runtime-only flags are set.
      static_assert((kAccValidClassFlags & kAccJavaFlagsMask) == kAccValidClassFlags,																					      static_assert((kAccValidClassFlags & kAccJavaFlagsMask) == kAccValidClassFlags,
                    "Valid class flags not a subset of Java flags");																							                    "Valid class flags not a subset of Java flags");
      static_assert((kAccValidInterfaceFlags & kAccJavaFlagsMask) == kAccValidInterfaceFlags,																				      static_assert((kAccValidInterfaceFlags & kAccJavaFlagsMask) == kAccValidInterfaceFlags,
                    "Valid interface flags not a subset of Java flags");																						                    "Valid interface flags not a subset of Java flags");

      if ((access_flags_ & kAccInterface) != 0) {																									      if ((access_flags_ & kAccInterface) != 0) {
        // Interface.																													        // Interface.
        return access_flags_ & kAccValidInterfaceFlags;																									        return access_flags_ & kAccValidInterfaceFlags;
      } else {																														      } else {
        // Class.																													        // Class.
        return access_flags_ & kAccValidClassFlags;																									        return access_flags_ & kAccValidClassFlags;
      }																															      }
    }																															    }

